# Honeypot Configuration - Copy to .env and customize
# NEVER commit .env to version control

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-super-secret-key-change-this-in-production

# Session Configuration
SESSION_SECRET=another-secret-key-for-session-hmac
SESSION_COOKIE_SECURE=1

# HTTPS and reverse proxy controls (recommended on VM/domain deployments)
FORCE_HTTPS=1
PREFERRED_URL_SCHEME=https
PROXY_FIX_ENABLED=1
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1

# Server Configuration (GCP VM)
HOST=0.0.0.0
PORT=5000
# Optional explicit bind override for upstream app process (leave empty to use HOST)
UPSTREAM_HOST=
# Auto-check/reload nginx when starting via webapp.py (Linux only)
WEBAPP_AUTO_NGINX=1

# Operator Dashboard (LOCAL ONLY - Never expose to internet)
OPERATOR_USERNAME=operator_admin
OPERATOR_PASSWORD=your_strong_operator_password_here
OPERATOR_PASSWORD_HASH=
OPERATOR_SECRET_KEY=your_random_secret_key_for_operator_sessions
OPERATOR_HOST=127.0.0.1
OPERATOR_PORT=5001
OPERATOR_SESSION_TIMEOUT_MINUTES=120
OPERATOR_FAILED_LOGIN_LIMIT=5
OPERATOR_LOCKOUT_SECONDS=300
OPERATOR_ACTIVE_WINDOW_MINUTES=15
OPERATOR_GROUP_ACTIVE_BY_IP=1
# Keep remote operator access disabled by default
ALLOW_REMOTE_OPERATOR=0

# Optional customer portal demo account password overrides
CUSTOMER_PASSWORD_NINA=ClientPortal!2026
CUSTOMER_PASSWORD_LIAM=ClientPortal!2026
CUSTOMER_PASSWORD_MAYA=ClientPortal!2026
